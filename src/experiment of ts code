// Using 'type' to define the structure
type ProductType = {
  saler: string;
  consumor: string;
};

// Using 'interface' to define the structure
interface ProductInterface {
  saler: string;
  consumor: string;
}

// Initializing the object with 'type'
const productType: ProductType = {
  saler: "sham",
  consumor: "joit",
};

// Initializing the object with 'interface'
const productInterface: ProductInterface = {
  saler: "sham",
  consumor: "joit",
};

// Using a variable to store the products
const products = {
  saler: string,
  consumor: string,
};
const products =products: {
  saler: "sham",
  consumor: "joit",
};

console.log(productType);
console.log(productInterface);
console.log(products);
